 SELECT * FROM vw_master LIMIT 5;

 ...................................................
 VIEWERSHIP BY PROVINCE
 ...................................................
 SELECT Province, COUNT(*) AS Views
FROM vw_master
GROUP BY Province
ORDER BY Views DESC;
....................................................
MOST WATCHED CHANNELS
....................................................
SELECT Channel, COUNT(*) AS Views
FROM vw_master
GROUP BY Channel
ORDER BY Views DESC
LIMIT 5;
...................................................
VIEWERSHIP BY GENDER
...................................................
SELECT Gender, COUNT(*) AS Views
FROM vw_master
GROUP BY Gender;
...................................................
AGE BUCKETS
...................................................
SELECT 
    CASE 
        WHEN Age < 18 THEN '0-17'
        WHEN Age BETWEEN 18 AND 34 THEN '18-34'
        WHEN Age BETWEEN 35 AND 54 THEN '35-54'
        ELSE '55+'
    END AS Age_Group,
    COUNT(*) AS Views
FROM vw_master
GROUP BY Age_Group;
...................................................
VIEWERSHIP BY TIMESLOTS
...................................................
SELECT 
    CASE 
        WHEN HOUR(Start_Time) BETWEEN 6 AND 11 THEN 'Morning'
        WHEN HOUR(Start_Time) BETWEEN 12 AND 17 THEN 'Afternoon'
        WHEN HOUR(Start_Time) BETWEEN 18 AND 23 THEN 'Evening'
        ELSE 'Night'
    END AS Time_Slot,
    COUNT(*) AS Total_Views
FROM vw_master
GROUP BY 
    CASE 
        WHEN HOUR(Start_Time) BETWEEN 6 AND 11 THEN 'Morning'
        WHEN HOUR(Start_Time) BETWEEN 12 AND 17 THEN 'Afternoon'
        WHEN HOUR(Start_Time) BETWEEN 18 AND 23 THEN 'Evening'
        ELSE 'Night'
    END
ORDER BY Total_Views DESC;
...................................................................
MALE VIEWERSHIP SPLIT BY RACE
..................................................................
SELECT 
    Race,
    COUNT(*) AS Total_Views
FROM vw_master
WHERE Gender = 'male'
GROUP BY Race
ORDER BY Total_Views DESC;
