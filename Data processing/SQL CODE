SELECT * FROM workspace.default.bright_tv_dataset LIMIT 5;
SELECT * FROM workspace.default.bright_tv_viewership LIMIT 5;

DESCRIBE workspace.default.bright_tv_viewership;

DROP TABLE workspace.default.bright_tv_viewership;

CREATE OR REPLACE TEMP VIEW vw_viewership_clean AS
SELECT 
    COALESCE(UserID0, userid4) AS UserID,
    COALESCE(Channel2, 'Unknown Channel') AS Channel,
    RecordDate2 AS Start_Time,
    
    -- Fix duration (if it's actually duration stored as timestamp)
    RecordDate2 + INTERVAL 1 HOUR AS End_Time

FROM workspace.default.bright_tv_viewership
WHERE COALESCE(UserID0, userid4) IS NOT NULL;

CREATE OR REPLACE TEMP VIEW vw_users_clean AS
SELECT 
    UserID,
    COALESCE(Age, 0) AS Age,
    COALESCE(Gender, 'Unknown') AS Gender,
    COALESCE(Province, 'Unknown') AS Province
FROM workspace.default.bright_tv_dataset
WHERE UserID IS NOT NULL;

CREATE OR REPLACE TEMP VIEW vw_master AS
SELECT 
    u.UserID,
    u.Age,
    u.Gender,
    u.Province,
    v.Channel,
    v.Start_Time,
    v.End_Time

FROM vw_users_clean u
INNER JOIN vw_viewership_clean v
    ON u.UserID = v.UserID;

